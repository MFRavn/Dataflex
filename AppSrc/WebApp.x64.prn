36861>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36863>>>>>>>        UChar[] ucaSalt
36864>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36865>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36868>>>>>>>        
36868>>>>>>>        If (num_arguments > 4) Begin
36870>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36871>>>>>>>        End
36871>>>>>>>>
36871>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36872>>>>>>>    End_Function
36873>>>>>>>    
36873>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36875>>>>>>>        Boolean bRequiresTimeCost
36875>>>>>>>        UInteger uiAlgo uiTimeCost
36875>>>>>>>        Integer iBegin iEnd
36875>>>>>>>        String sSalt
36875>>>>>>>        
36875>>>>>>>        Move 1 to iBegin
36876>>>>>>>        
36876>>>>>>>        // Parse Algo
36876>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36877>>>>>>>        If (not(iEnd)) Function_Return False
36880>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36881>>>>>>>        
36881>>>>>>>        // Parse Salt
36881>>>>>>>        Move (iEnd + 1) to iBegin
36882>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36883>>>>>>>        If (not(iEnd)) Function_Return False
36886>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36887>>>>>>>        
36887>>>>>>>        Case Begin
36887>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36889>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36892>>>>>>>                Move True to bRequiresTimeCost
36893>>>>>>>                Case Break
36894>>>>>>>            Case Else
36894>>>>>>>                Error 8710 "Invalid algorithm selected."
36895>>>>>>>>
36895>>>>>>>                Function_Return False
36896>>>>>>>        Case End
36896>>>>>>>        
36896>>>>>>>        // Parse optional timecost
36896>>>>>>>        If (bRequiresTimeCost) Begin
36898>>>>>>>            Move (iEnd + 1) to iBegin
36899>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36900>>>>>>>            If (not(iEnd)) Function_Return False
36903>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36904>>>>>>>        End
36904>>>>>>>>
36904>>>>>>>        
36904>>>>>>>        // Parse rest hash
36904>>>>>>>        Move (iEnd + 1) to iBegin
36905>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36906>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36909>>>>>>>        
36909>>>>>>>        // Base64Decode
36909>>>>>>>        UChar[] ucaSalt
36910>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36911>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36914>>>>>>>        
36914>>>>>>>        // Create new hash
36914>>>>>>>        String sNewHash
36914>>>>>>>        If (bRequiresTimeCost) Begin
36916>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36918>>>>>>>                Function_Return False 
36919>>>>>>>            End
36919>>>>>>>>
36919>>>>>>>        End
36919>>>>>>>>
36919>>>>>>>        Else Begin
36920>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36922>>>>>>>                Function_Return False 
36923>>>>>>>            End
36923>>>>>>>>
36923>>>>>>>        End
36923>>>>>>>>
36923>>>>>>>        Function_Return (sNewHash = sHash)
36924>>>>>>>    End_Function
36925>>>>>>>    
36925>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36927>>>>>>>        Boolean bRequireTimeCost
36927>>>>>>>        UBigInt ullSize
36927>>>>>>>        UChar[] ucaSalt
36928>>>>>>>        String sSalt
36928>>>>>>>        
36928>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36929>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36930>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36933>>>>>>>        
36933>>>>>>>        Case Begin
36933>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36935>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36936>>>>>>>                Move True to bRequireTimeCost
36937>>>>>>>                Case Break
36938>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36941>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36942>>>>>>>                Move True to bRequireTimeCost
36943>>>>>>>                Case Break
36944>>>>>>>            Case Else
36944>>>>>>>                Error 8710 "Invalid algorithm selected."
36945>>>>>>>>
36945>>>>>>>                Function_Return 0
36946>>>>>>>        Case End
36946>>>>>>>        
36946>>>>>>>        // calculate base64 in a non-floating-manner
36946>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36947>>>>>>>        
36947>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36948>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36949>>>>>>>        If (bRequireTimeCost) Begin
36951>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36952>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36953>>>>>>>        End
36953>>>>>>>>
36953>>>>>>>        Else Begin
36954>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36955>>>>>>>        End
36955>>>>>>>>
36955>>>>>>>        
36955>>>>>>>        Function_Return ullSize
36956>>>>>>>    End_Function
36957>>>>>>>End_Class
