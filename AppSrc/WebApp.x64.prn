36632>>>>>>>    //
36632>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36632>>>>>>>    //
36632>>>>>>>    //  Params:
36632>>>>>>>    //      dtTime  Time to convert
36632>>>>>>>    //  Returns:
36632>>>>>>>    //      String with "HH:MM:SS" format
36632>>>>>>>    //
36632>>>>>>>    Function TimeToString DateTime dtTime Returns String
36634>>>>>>>        String sHours sMinutes sSeconds
36634>>>>>>>        
36634>>>>>>>        //  Extract parts
36634>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36635>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36636>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36637>>>>>>>        
36637>>>>>>>        //  Fill out with 0
36637>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36640>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36643>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36646>>>>>>>        
36646>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36647>>>>>>>    End_Function
