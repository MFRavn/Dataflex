37852>>>>>            // Validación: Bloquea el guardado si la liga destino superó su capacidad.
37852>>>>>        Function Validate_Save Returns Integer
37854>>>>>            Integer iRetVal
37854>>>>>            Boolean bEsNuevo bCambiandoLiga
37854>>>>>            
37854>>>>>            // Determinamos si es una inserción (registro nuevo)
37854>>>>>            Get HasRecord to bEsNuevo
37855>>>>>            Move (not(bEsNuevo)) to bEsNuevo 
37856>>>>>        
37856>>>>>            // Verificamos si hubo cambio en la clave foránea de la liga
37856>>>>>            Get Field_Changed_State Field equipo.LigaID to bCambiandoLiga
37857>>>>>            
37857>>>>>            // La validación de cupo solo aplica al insertar o mover de liga
37857>>>>>            If (bEsNuevo or bCambiandoLiga) Begin
37859>>>>>                If (liga.Equipos >= liga.EquiposMax) Begin
37861>>>>>                    Send UserError "La liga seleccionada ya ha alcanzado el máximo de equipos permitidos" "Capacidad Agotada"
37862>>>>>                    Function_Return 1 // Indica que la validación falló
37863>>>>>                End
37863>>>>>>
37863>>>>>            End
37863>>>>>>
37863>>>>>        
37863>>>>>            // Ejecuta validaciones de la clase padre y retorna su resultado
37863>>>>>            Forward Get Validate_Save to iRetVal
37865>>>>>            If (bEsNuevo or bCambiandoLiga) Begin
37867>>>>>                // Solo validamos si el equipo REALMENTE tiene una liga asignada
37867>>>>>                If (equipo.LigaID <> 0) Begin 
37869>>>>>                    If (liga.Equipos >= liga.EquiposMax) Begin
37871>>>>>                        Send UserError "La liga seleccionada ya ha alcanzado el máximo..." "Error"
37872>>>>>                        Function_Return 1
37873>>>>>                    End
37873>>>>>>
37873>>>>>                End
37873>>>>>>
37873>>>>>            End
37873>>>>>>
37873>>>>>            Function_Return iRetVal
37874>>>>>        End_Function
37875>>>>>        
37875>>>>>        // Se ejecuta al insertar o antes de una actualización de registro
37875>>>>>        Procedure Update
37877>>>>>            Forward Send Update
37879>>>>>            // Actualiza el contador en la tabla relacionada (Padre)
37879>>>>>            Increment liga.Equipos
37880>>>>>        End_Procedure
37881>>>>>        
37881>>>>>        // Se ejecuta al eliminar o antes de limpiar un registro para actualizarlo
37881>>>>>        Procedure Backout
37883>>>>>            Forward Send Backout
37885>>>>>            // Decrementa el contador en la tabla relacionada (Padre)
37885>>>>>            If (liga.Equipos > 0) Begin
37887>>>>>                Decrement liga.Equipos
37888>>>>>            End
37888>>>>>>
37888>>>>>        End_Procedure
37889>>>>>
