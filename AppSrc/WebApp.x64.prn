38607>>>    // This can be used to show and hide buttons based on context.
38607>>>    // This can be called any time the view is active.
38607>>>    Procedure SetActionButtons
38610>>>        tWebNavigateData NavigateData
38610>>>        tWebNavigateData NavigateData
38610>>>        Boolean bHasRecord
38610>>>        Handle hoDD
38610>>>
38610>>>        Get Server to hoDD
38611>>>        Get GetNavigateData to NavigateData
38612>>>        
38612>>>        If (hoDD) Begin
38614>>>            Get HasRecord of hoDD to bHasRecord
38615>>>        End
38615>>>>
38615>>>        Else Begin
38616>>>            Move False to bHasRecord
38617>>>        End
38617>>>>
38617>>>
38617>>>        // let's hide all buttons and then show the ones we want
38617>>>        WebSet pbRender of oEditBtn to False 
38618>>>        WebSet pbRender of oSaveBtn to False
38619>>>        WebSet pbRender of oCancelChangesBtn to False
38620>>>        WebSet pbRender of oDeleteBtn to False
38621>>>
38621>>>        If (NavigateData.bReadOnly) Begin 
38623>>>            WebSet pbRender of oEditBtn to True 
38624>>>        End
38624>>>>
38624>>>        Else Begin
38625>>>            WebSet pbRender of oSaveBtn to True
38626>>>            WebSet pbRender of oCancelChangesBtn to True
38627>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38628>>>        End
38628>>>>
38628>>>    End_Procedure
