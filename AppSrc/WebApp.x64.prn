38639>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38642>>>
38642>>>        // if this view is being used in multiple contexts, you may need a block of code
38642>>>        // like this to handle customizations. This would include hiding rows and buttons
38642>>>        // (WebSet pbRender) and changing the values of various captions.
38642>>>        Case Begin
38642>>>            Case (NavigateData.eNavigateType = nfFromMain)
38644>>>                // If from main, this is a probably a main file Select to Zoom.
38644>>>                // This is the most typical way to navigate to a zoom.
38644>>>                Case Break
38645>>>                
38645>>>            Case (NavigateData.eNavigateType = nfFromParent)
38648>>>                // If from parent, this is a constrained drill down.
38648>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38648>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38648>>>                Case Break
38649>>>                
38649>>>            Case (NavigateData.eNavigateType = nfFromChild)
38652>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38652>>>                // This is unusual, but it might be used for adding a new child record.
38652>>>                Case Break
38653>>>                
38653>>>            Case Else // must be nfUndefined
38653>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38653>>>                // You may want to check NavigateData.NamedValues.
38653>>>                  
38653>>>        Case End
38653>>>
38653>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38653>>>        // It's best to set these buttons in their own procedure so you can change later.
38653>>>        Send SetActionButtons
38654>>>
38654>>>        If (HasRecord(Server(Self))) Begin 
38656>>>            Send SetHeaderCaption    ("Equipo:"*equipo.Nombre)
38657>>>            Send SetBreadcrumbCaption equipo.Nombre
38658>>>        End
38658>>>>
38658>>>        Else Begin 
38659>>>            Send SetHeaderCaption     "Nuevo equipo"
38660>>>            Send SetBreadcrumbCaption "Nuevo"
38661>>>        End
38661>>>>
38661>>>    End_Procedure
