37908>>>        WebSet pbRender of oEditBtn to False
37909>>>        WebSet pbRender of oSaveBtn to False
37910>>>        WebSet pbRender of oCancelChangesBtn to False
37911>>>        WebSet pbRender of oDeleteBtn to False
37912>>>
37912>>>        If (NavigateData.bReadOnly) Begin
