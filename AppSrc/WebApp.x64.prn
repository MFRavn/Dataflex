38793>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38796>>>        Case Begin
38796>>>            Case (NavigateData.eNavigateType = nfFromMain)
38798>>>                // If from main, this is a propbably a main file Select to Zoom.
38798>>>                Case Break
38799>>>
38799>>>            Case (NavigateData.eNavigateType = nfFromParent)
38802>>>                // If from parent, this is a constrained drill down.
38802>>>                Case Break
38803>>>
38803>>>            Case (NavigateData.eNavigateType = nfFromChild)
38806>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38806>>>                Case Break
38807>>>
38807>>>            Case Else // must be nfUndefined
38807>>>
38807>>>        Case End
38807>>>        
38807>>>        If (HasRecord(Server(Self))) Begin 
38809>>>            Send SetHeaderCaption    ("Entrenador:"*entrenador.Nombre*entrenador.Apellido*"("+equipo.Nombre+")")
38810>>>            Send SetBreadcrumbCaption (entrenador.Nombre*entrenador.Apellido)
38811>>>        End
38811>>>>
38811>>>        Else Begin 
38812>>>            Send SetHeaderCaption     "Nuevo Entrenador"
38813>>>            Send SetBreadcrumbCaption "Nuevo"
38814>>>        End
38814>>>>
38814>>>        
38814>>>        Send SetActionButtons
38815>>>
38815>>>    End_Procedure
38816>>>
38816>>>End_Object 
