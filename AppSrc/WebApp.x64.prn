38983>>>    // This can be used to show and hide buttons based on context.
38983>>>    // This can be called any time the view is active.
38983>>>    Procedure SetActionButtons
38986>>>        tWebNavigateData NavigateData
38986>>>        tWebNavigateData NavigateData
38986>>>        Boolean bHasRecord
38986>>>        Handle hoDD
38986>>>
38986>>>        Get Server to hoDD
38987>>>        Get GetNavigateData to NavigateData
38988>>>        
38988>>>        If (hoDD) Begin
38990>>>            Get HasRecord of hoDD to bHasRecord
38991>>>        End
38991>>>>
38991>>>        Else Begin
38992>>>            Move False to bHasRecord
38993>>>        End
38993>>>>
38993>>>
38993>>>        // let's hide all buttons and then show the ones we want
38993>>>        WebSet pbRender of oEditBtn to False 
38994>>>        WebSet pbRender of oSaveBtn to False
38995>>>        WebSet pbRender of oCancelChangesBtn to False
38996>>>        WebSet pbRender of oDeleteBtn to False
38997>>>
38997>>>        If (NavigateData.bReadOnly) Begin 
38999>>>            WebSet pbRender of oEditBtn to True 
39000>>>        End
39000>>>>
39000>>>        Else Begin
39001>>>            WebSet pbRender of oSaveBtn to True
39002>>>            WebSet pbRender of oCancelChangesBtn to True
39003>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39004>>>        End
39004>>>>
39004>>>    End_Procedure
39005>>>
39005>>>    // this will close the view after a save
39005>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
39008>>>        Send NavigateClose Self
39009>>>    End_Procedure
39010>>>
39010>>>    // this will close the view after a delete
39010>>>    Procedure OnViewDeleted Handle hoDDO
39013>>>        Send NavigateClose Self
39014>>>    End_Procedure
39015>>>
39015>>>    // Add code to customize your Zoom View based on how it was invoked.
39015>>>    // Use NavigateData to determine the context this view will be used in.
39015>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39018>>>
39018>>>        // if this view is being used in multiple contexts, you may need a block of code
39018>>>        // like this to handle customizations. This would include hiding rows and buttons
39018>>>        // (WebSet pbRender) and changing the values of various captions.
39018>>>        Case Begin
39018>>>            Case (NavigateData.eNavigateType = nfFromMain)
39020>>>                // If from main, this is a probably a main file Select to Zoom.
39020>>>                // This is the most typical way to navigate to a zoom.
39020>>>                Case Break
39021>>>                
39021>>>            Case (NavigateData.eNavigateType = nfFromParent)
39024>>>                // If from parent, this is a constrained drill down.
39024>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
39024>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
39024>>>                Case Break
39025>>>                
39025>>>            Case (NavigateData.eNavigateType = nfFromChild)
39028>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
39028>>>                // This is unusual, but it might be used for adding a new child record.
39028>>>                Case Break
39029>>>                
39029>>>            Case Else // must be nfUndefined
39029>>>                // This may be the start of a query or this may be used for some kind of custom operation.
39029>>>                // You may want to check NavigateData.NamedValues.
39029>>>                  
39029>>>        Case End
39029>>>
39029>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
39029>>>        // It's best to set these buttons in their own procedure so you can change later.
39029>>>        Send SetActionButtons
39030>>>
39030>>>        If (HasRecord(Server(Self))) Begin 
39032>>>            Send SetHeaderCaption    ("Entrenador:"*entrenador.Nombre)
39033>>>            Send SetBreadcrumbCaption entrenador.Nombre
39034>>>        End
39034>>>>
39034>>>        Else Begin 
39035>>>            Send SetHeaderCaption     "Nuevo entrenador"
39036>>>            Send SetBreadcrumbCaption "Nuevo"
39037>>>        End
39037>>>>
39037>>>    End_Procedure
39038>>>
39038>>>End_Object
