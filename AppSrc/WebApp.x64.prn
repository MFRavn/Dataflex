40628>>>    Procedure SetActionButtons
40631>>>        tWebNavigateData NavigateData
40631>>>        tWebNavigateData NavigateData
40631>>>        Boolean bHasRecord
40631>>>        Handle hoDD
40631>>>
40631>>>        Get Server to hoDD
40632>>>        Get GetNavigateData to NavigateData
40633>>>        Get HasRecord of hoDD to bHasRecord
40634>>>
40634>>>        // let's hide all buttons and then Show the ones we want
40634>>>        WebSet pbRender of oEditBtn to False
40635>>>        WebSet pbRender of oSaveBtn to False
40636>>>        WebSet pbRender of oCancelChangesBtn to False
40637>>>        WebSet pbRender of oDeleteBtn to False
40638>>>
40638>>>        If (NavigateData.bReadOnly) Begin
40640>>>            WebSet pbRender of oEditBtn to True
40641>>>        End
40641>>>>
40641>>>        Else Begin
40642>>>            WebSet pbRender of oSaveBtn to True
40643>>>            WebSet pbRender of oCancelChangesBtn to True
40644>>>            WebSet pbRender of oDeleteBtn to bHasRecord
40645>>>        End
40645>>>>
40645>>>    End_Procedure
40646>>>
