37930>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37933>>>        Forward Send OnNavigateForward NavigateData hoInvokingView hoInvokingObject
37935>>>        
37935>>>        If (HasRecord(oliga_DD)) Begin 
37937>>>            Send SetHeaderCaption    ("Liga:"*liga.Nombre*liga.pais)
37938>>>            Send SetBreadcrumbCaption (liga.Nombre)
37939>>>            
37939>>>            // --- ESTO ES LO QUE FALTA ---
37939>>>            // 1. Forzamos al DDO de entrenadores a recalcular el filtro con la nueva Liga
37939>>>            Send Rebuild_Constraints of oentrenador_DD
37940>>>            
37940>>>            // 2. Refrescamos las listas para que pidan los datos al servidor
37940>>>            Send GridRefresh of oEquiposList
37941>>>            Send GridRefresh of oEntrenadoresList
37942>>>        End
37942>>>>
37942>>>        Else Begin 
37943>>>            Send SetHeaderCaption     "Nueva Liga"
37944>>>            Send SetBreadcrumbCaption "Nuevo"
37945>>>        End
37945>>>>
37945>>>
37945>>>        Send SetActionButtons
37946>>>    End_Procedure
