38227>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38230>>>
38230>>>        // if this view is being used in multiple contexts, you may need a block of code
38230>>>        // like this to handle customizations. This would include hiding rows and buttons
38230>>>        // (WebSet pbRender) and changing the values of various captions.
38230>>>        Case Begin
38230>>>            Case (NavigateData.eNavigateType = nfFromMain)
38232>>>                // If from main, this is a probably a main file Select to Zoom.
38232>>>                // This is the most typical way to navigate to a zoom.
38232>>>                Case Break
38233>>>                
38233>>>            Case (NavigateData.eNavigateType = nfFromParent)
38236>>>                // If from parent, this is a constrained drill down.
38236>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38236>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38236>>>                Case Break
38237>>>                
38237>>>            Case (NavigateData.eNavigateType = nfFromChild)
38240>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38240>>>                // This is unusual, but it might be used for adding a new child record.
38240>>>                Case Break
38241>>>                
38241>>>            Case Else // must be nfUndefined
38241>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38241>>>                // You may want to check NavigateData.NamedValues.
38241>>>                  
38241>>>        Case End
38241>>>
38241>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38241>>>        // It's best to set these buttons in their own procedure so you can change later.
38241>>>        Send SetActionButtons
38242>>>        
38242>>>        If (HasRecord(Server(Self))) Begin 
38244>>>            Send SetHeaderCaption    ("Liga:"*liga.Nombre)
38245>>>            Send SetBreadcrumbCaption liga.Nombre
38246>>>        End
38246>>>>
38246>>>        Else Begin 
38247>>>            Send SetHeaderCaption     "Nueva Liga"
38248>>>            Send SetBreadcrumbCaption "Nueva"
38249>>>        End
38249>>>>
38249>>>        //------         
38249>>>        Integer iLigaID
38249>>>        Move liga.ID to iLigaID
38250>>>        WebSet piLigaID of Self to iLigaID
38251>>>        
38251>>>        Send Rebuild_Constraints of oJugadorDD
38252>>>        Send RefreshListFromDD of oJugadoresEquipo_List
38253>>>        
38253>>>        Send Rebuild_Constraints of oEntrenadorDD
38254>>>        Send RefreshListFromDD of oEntrenadorEquipo_List
38255>>>        //------
38255>>>    End_Procedure
