37983>>>        
37983>>>        Procedure OnConstrain
37986>>>            Forward Send OnConstrain
37988>>>            
37988>>>            Integer iLigaID iCont
37988>>>            String[] saEquiposDeLigaID
37989>>>            String sConsulta
37989>>>            
37989>>>            Send Request_Clear of Self
37990>>>            
37990>>>            Get Field_Current_Value of oLigaDD Field liga.ID to iLigaID
37991>>>           
37991>>>            Move iLigaID to equipo.LigaID
37992>>>            Send Request_Read to oEquipoDD FIRST_RECORD equipo.File_Number 1
37993>>>            While (Found)
37997>>>                Move equipo.ID to saEquiposDeLigaID[-1]                   
37998>>>                Send Request_Read to oEquipoDD NEXT_RECORD equipo.File_Number 1
37999>>>            Loop
38000>>>>
38000>>>            If (SizeOfArray(saEquiposDeLigaID) > 0) Begin
38002>>>                Move ("(jugador.equipoID = " + String(saEquiposDeLigaID[0]) + ")") to sConsulta                
38003>>>                For iCont from 1 to (SizeOfArray(saEquiposDeLigaID) - 1)
38009>>>>
38009>>>                    Move (sConsulta + " OR (jugador.equipoID = " + String(saEquiposDeLigaID[iCont]) + ")") to sConsulta
38010>>>                Loop                
38011>>>>
38011>>>            End            
38011>>>>
38011>>>            Set psSQLFilter to ("("+ sConsulta + ")")
38012>>>        End_Procedure
38013>>>        
