38195>>>    // This can be used to show and hide buttons based on context.
38195>>>    // This can be called any time the view is active.
38195>>>    Procedure SetActionButtons
38198>>>        tWebNavigateData NavigateData
38198>>>        tWebNavigateData NavigateData
38198>>>        Boolean bHasRecord
38198>>>        Handle hoDD
38198>>>
38198>>>        Get Server to hoDD
38199>>>
38199>>>        Get GetNavigateData to NavigateData
38200>>>        
38200>>>        If (hoDD) Begin
38202>>>            Get HasRecord of hoDD to bHasRecord
38203>>>        End
38203>>>>
38203>>>        Else Begin
38204>>>            Move False to bHasRecord
38205>>>        End
38205>>>>
38205>>>
38205>>>        // let's hide all buttons and then show the ones we want
38205>>>        WebSet pbRender of oEditBtn to False 
38206>>>        WebSet pbRender of oSaveBtn to False
38207>>>        WebSet pbRender of oCancelChangesBtn to False
38208>>>        WebSet pbRender of oDeleteBtn to False
38209>>>
38209>>>        If (NavigateData.bReadOnly) Begin 
38211>>>            WebSet pbRender of oEditBtn to True 
38212>>>        End
38212>>>>
38212>>>        Else Begin
38213>>>            WebSet pbRender of oSaveBtn to True
38214>>>            WebSet pbRender of oCancelChangesBtn to True
38215>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38216>>>        End
38216>>>>
38216>>>    End_Procedure
