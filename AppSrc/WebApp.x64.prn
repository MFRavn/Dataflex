39635>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39638>>>        Handle hoDD
39638>>>        RowID riJugador
39638>>>        Get Server to hoDD
39639>>>        
39639>>>        Forward Send OnNavigateForward NavigateData hoInvokingView hoInvokingObject
39641>>>        Case Begin
39641>>>            Case (NavigateData.eNavigateType = nfFromMain)
39643>>>                // PASO CLAVE: Convertir el String sRowId a un tipo RowID real
39643>>>                Move (DeserializeRowID(NavigateData.sRowId)) to riJugador
39644>>>                // Ahora pasamos la variable riJugador (que ya es RowID) en lugar del String
39644>>>                Send FindByRowId of hoDD jugador.File_Number riJugador
39645>>>                Case Break
39646>>>
39646>>>            //Case (NavigateData.eNavigateType = nfFromParent)
39646>>>                // If from parent, this is a constrained drill down.
39646>>>                //Case Break
39646>>>
39646>>>            //Case (NavigateData.eNavigateType = nfFromChild)
39646>>>                // If from child, this is a probably a parent Zoom from a Zoom.
39646>>>                //Case Break
39646>>>
39646>>>            //Case Else // must be nfUndefined
39646>>>
39646>>>        Case End
39646>>>        
39646>>>        If (HasRecord(hoDD)) Begin 
39648>>>            // Corregido: Usamos '+' y Trim para una mejor presentación del título
39648>>>            Send SetHeaderCaption ("Jugador: " + Trim(jugador.Nombre) + " " + Trim(jugador.Apellido) + " (" + Trim(equipo.Nombre) + ")")
39649>>>            Send SetBreadcrumbCaption (Trim(jugador.Nombre) + " " + Trim(jugador.Apellido))
39650>>>        End
39650>>>>
39650>>>        Else Begin 
39651>>>            Send SetHeaderCaption "Nuevo Jugador"
39652>>>            Send SetBreadcrumbCaption "Nuevo"
39653>>>        End
39653>>>>
39653>>>
39653>>>        Send SetActionButtons
39654>>>
39654>>>    End_Procedure
39655>>>
39655>>>End_Object 
