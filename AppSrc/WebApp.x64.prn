36824>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36826>>>>>>>        Boolean bOk bRequireTimeCost
36826>>>>>>>        UChar[] ucaHash
36827>>>>>>>        
36827>>>>>>>        Case Begin
36827>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36829>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36830>>>>>>>                If (not(bOk)) Function_Return False
36833>>>>>>>                
36833>>>>>>>                Move True to bRequireTimeCost
36834>>>>>>>                Case Break
36835>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36838>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36839>>>>>>>                If (not(bOk)) Function_Return False
36842>>>>>>>                
36842>>>>>>>                Move True to bRequireTimeCost
36843>>>>>>>                Case Break
36844>>>>>>>            Case Else
36844>>>>>>>                Error 8710 "Invalid algorithm selected."
36845>>>>>>>>
36845>>>>>>>                Function_Return False
36846>>>>>>>        Case End
36846>>>>>>>        
36846>>>>>>>        String sSalt
36846>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36847>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36850>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36851>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36854>>>>>>>        
36854>>>>>>>        If (bRequireTimeCost) Begin
36856>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36857>>>>>>>        End
36857>>>>>>>>
36857>>>>>>>        Else Begin
36858>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36859>>>>>>>        End
36859>>>>>>>>
36859>>>>>>>        
36859>>>>>>>        Function_Return bOk
36860>>>>>>>    End_Function
