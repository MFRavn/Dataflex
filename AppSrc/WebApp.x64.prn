38765>>>    Procedure SetActionButtons
38768>>>        tWebNavigateData NavigateData
38768>>>        tWebNavigateData NavigateData
38768>>>        Boolean bHasRecord
38768>>>        Handle hoDD
38768>>>
38768>>>        Get Server to hoDD
38769>>>        Get GetNavigateData to NavigateData
38770>>>        Get HasRecord of hoDD to bHasRecord
38771>>>
38771>>>        // let's hide all buttons and then Show the ones we want
38771>>>        WebSet pbRender of oEditBtn to False
38772>>>        WebSet pbRender of oSaveBtn to False
38773>>>        WebSet pbRender of oCancelChangesBtn to False
38774>>>        WebSet pbRender of oDeleteBtn to False
38775>>>
38775>>>        If (NavigateData.bReadOnly) Begin
38777>>>            WebSet pbRender of oEditBtn to True
38778>>>        End
38778>>>>
38778>>>        Else Begin
38779>>>            WebSet pbRender of oSaveBtn to True
38780>>>            WebSet pbRender of oCancelChangesBtn to True
38781>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38782>>>        End
38782>>>>
38782>>>    End_Procedure
