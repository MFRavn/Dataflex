36958>>>>>>>Class cPasswordHasher is a cObject
36959>>>>>>>    
36959>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36960>>>>>>>    
36960>>>>>>>    Procedure Construct_Object
36962>>>>>>>        Forward Send Construct_Object
36964>>>>>>>        
36964>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36965>>>>>>>        Property UInteger   puiSaltSize         16
36966>>>>>>>        
36966>>>>>>>        Property UInteger   puiOptTimeCost      420000
36967>>>>>>>    End_Procedure
36968>>>>>>>    
36968>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36970>>>>>>>        Boolean bOk
36970>>>>>>>        UInteger uiAlgo
36970>>>>>>>        Get peAlgorithm to uiAlgo
36971>>>>>>>        
36971>>>>>>>        Case Begin
36971>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36973>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36976>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36977>>>>>>>                Case Break
36978>>>>>>>            Case Else
36978>>>>>>>                Error 8710 "Invalid algorithm selected."
36979>>>>>>>>
36979>>>>>>>                Function_Return False
36980>>>>>>>        Case End
36980>>>>>>>        
36980>>>>>>>        Function_Return bOk
36981>>>>>>>    End_Function
36982>>>>>>>    
36982>>>>>>>    Function RequiredBufferSize Returns UBigInt
36984>>>>>>>        UBigInt ullSize
36984>>>>>>>        UInteger uiAlgo
36984>>>>>>>        Get peAlgorithm to uiAlgo
36985>>>>>>>        
36985>>>>>>>        Case Begin
36985>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36987>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36990>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36991>>>>>>>                Case Break
36992>>>>>>>            Case Else
36992>>>>>>>                Error 8710 "Invalid algorithm selected."
36993>>>>>>>>
36993>>>>>>>                Function_Return 0
36994>>>>>>>        Case End
36994>>>>>>>        
36994>>>>>>>        Function_Return ullSize
36995>>>>>>>    End_Function
36996>>>>>>>
36996>>>>>>>End_Class
