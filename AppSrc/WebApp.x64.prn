39942>>>    // Add code to customize your Select View based on how it was invoked.
39942>>>    // Use NavigateData to determine the context this view will be used in.
39942>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39945>>>
39945>>>        // if this view is being used in multiple contexts, you may need a block of code
39945>>>        // like this to handle customizations. This would include hiding rows and buttons
39945>>>        // (WebSet pbRender) and changing the values of various captions.
39945>>>        
39945>>>        String sDesdeDondeVengo
39945>>>        Case Begin
39945>>>            Case (NavigateData.eNavigateType=nfFromParent)
39947>>>                // If from parent, this is a constrained drill down.
39947>>>                // If needed you could check NavigateData.iTable to determine the constraining parent.
39947>>>                Move "Padre" to sDesdeDondeVengo
39948>>>                Case Break
39949>>>                
39949>>>            Case (NavigateData.eNavigateType=nfFromChild)
39952>>>                // If from child, this is a probably a parent lookup from a Zoom
39952>>>                Move "Hijo" to sDesdeDondeVengo
39953>>>                Case Break
39954>>>                
39954>>>            Case (NavigateData.eNavigateType=nfFromMain)
39957>>>                // If from main, this is a propbably a main file lookup from a Zoom.
39957>>>                // This is not used often with the drilldown style
39957>>>                Move "Hermano" to sDesdeDondeVengo
39958>>>                Case Break
39959>>>                
39959>>>            Case Else // must be nfUndefined
39959>>>                // This may be the start of a drilldown query or some kind ofcustom query.
39959>>>                // You may want to check NavigateData.NamedValues.
39959>>>                  
39959>>>        Case End
39959>>>            
39959>>>        Send SetHeaderCaption    ("Posiciones de:"*Jugador.Nombre*jugador.Apellido)
39960>>>        Send SetBreadcrumbCaption ("Sus posiciones")     
39961>>>        
39961>>>        Send RefreshListFromDD of oPosicionesTotales_List
39962>>>        
39962>>>        //------
39962>>>        String sRowID
39962>>>        Integer iMiTabla iMiCol
39962>>>        Move (NavigateData.sRowID) to sRowID
39963>>>        Move (NavigateData.iTable) to iMiTabla
39964>>>        Move (NavigateData.iColumn) to iMiCol
39965>>>        
39965>>>        //------
39965>>>    End_Procedure
39966>>>
39966>>>End_Object
