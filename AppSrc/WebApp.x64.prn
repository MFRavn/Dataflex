39610>>>        Boolean bHasRecord
39610>>>        Handle hoDD
39610>>>
39610>>>        Get Server to hoDD
39611>>>        Get GetNavigateData to NavigateData
39612>>>        Get HasRecord of hoDD to bHasRecord
39613>>>
39613>>>        // let's hide all buttons and then Show the ones we want
39613>>>        WebSet pbRender of oEditBtn to False
39614>>>        WebSet pbRender of oSaveBtn to False
39615>>>        WebSet pbRender of oCancelChangesBtn to False
39616>>>        WebSet pbRender of oDeleteBtn to False
39617>>>
39617>>>        If (NavigateData.bReadOnly) Begin
39619>>>            WebSet pbRender of oEditBtn to True
39620>>>        End
39620>>>>
39620>>>        Else Begin
39621>>>            WebSet pbRender of oSaveBtn to True
39622>>>            WebSet pbRender of oCancelChangesBtn to True
39623>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39624>>>        End
39624>>>>
39624>>>    End_Procedure
