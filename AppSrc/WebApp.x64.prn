40661>>>                Case Break
40662>>>
40662>>>            Case (NavigateData.eNavigateType = nfFromParent)
40665>>>                // If from parent, this is a constrained drill down.
40665>>>                Case Break
40666>>>
40666>>>            Case (NavigateData.eNavigateType = nfFromChild)
40669>>>                // If from child, this is a probably a parent Zoom from a Zoom.
40669>>>                Case Break
40670>>>
40670>>>            Case Else // must be nfUndefined
40670>>>
40670>>>        Case End
40670>>>
40670>>>        Send SetActionButtons
40671>>>
40671>>>    End_Procedure
40672>>>
40672>>>End_Object 
