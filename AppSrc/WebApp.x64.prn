36793>>>>>>>    Function RandomBuffer UInteger uiSize Returns UChar[]
36795>>>>>>>        UChar[] ucaBuffer
36796>>>>>>>        Move (ResizeArray(ucaBuffer, uiSize)) to ucaBuffer
36797>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
36799>>>>>>>            Error 8710 "Failed to create random buffer."
36800>>>>>>>>
36800>>>>>>>        End
36800>>>>>>>>
36800>>>>>>>        Function_Return ucaBuffer
36801>>>>>>>    End_Function
36802>>>>>>>    
36802>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36804>>>>>>>        Integer iErr
36804>>>>>>>        Pointer pBase64
36804>>>>>>>        String sBase64
36804>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36805>>>>>>>        If (not(pBase64)) Begin
36807>>>>>>>            Function_Return sBase64
36808>>>>>>>        End
36808>>>>>>>>
36808>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36809>>>>>>>        Move (Free(pBase64)) to iErr
36810>>>>>>>        Function_Return sBase64
36811>>>>>>>    End_Function
36812>>>>>>>    
36812>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36814>>>>>>>        Integer iLen
36814>>>>>>>        Pointer pBase64
36814>>>>>>>        UChar[] ucaBuffer
36815>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36816>>>>>>>        If (not(pBase64)) Begin
36818>>>>>>>            Function_Return ucaBuffer
36819>>>>>>>        End
36819>>>>>>>>
36819>>>>>>>        
36819>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36820>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36821>>>>>>>        Move (Free(pBase64)) to iLen
36822>>>>>>>        Function_Return ucaBuffer
36823>>>>>>>    End_Function
