37758>>>   Object oentrenador_DD is a centrenadorDataDictionary
37760>>>        Set DDO_Server to oequipo_DD
37761>>>
37761>>>        // Función corregida: Buscamos si el equipo del entrenador pertenece a la liga actual
37761>>>        Function EsEquipoDeLaLiga Integer iEqID Returns Boolean
37764>>>            Integer iLigaActual
37764>>>            // Obtenemos el ID de la liga que estamos viendo
37764>>>            Get Field_Current_Value of oliga_DD Field liga.ID to iLigaActual
37765>>>            
37765>>>            // Si no hay liga cargada, no mostramos nada
37765>>>            If (iLigaActual = 0) Function_Return False
37768>>>
37768>>>            // Buscamos el equipo en el buffer global (sin afectar al DDO)
37768>>>            Clear equipo
37769>>>            Move iEqID to equipo.ID
37770>>>            Find eq equipo.ID
37771>>>>
37771>>>            
37771>>>            // Si el equipo existe y su LigaID es la que buscamos, devolvemos True
37771>>>            Function_Return (Found and equipo.LigaID = iLigaActual)
37772>>>        End_Function
37773>>>
37773>>>        Procedure OnConstrain
37776>>>            Forward Send OnConstrain
37778>>>            // Usamos la lógica de tu tutor: Constrain AS
37778>>>            Constrain entrenador as (EsEquipoDeLaLiga(Self, entrenador.EquipoID))
37779>>>        End_Procedure
37780>>>    End_Object
