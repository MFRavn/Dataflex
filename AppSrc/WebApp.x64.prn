36997>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36998>>>>>    
36998>>>>>    Procedure Construct_Object
37000>>>>>        Handle hoObj
37000>>>>>        
37000>>>>>        Forward Send Construct_Object
37002>>>>>        
37002>>>>>        Set pbSessionCookieHttpOnly to True
37003>>>>>        
37003>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
37004>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
37005>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
37006>>>>>        
37006>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
37007>>>>>        Set phoUserDD to hoObj
37008>>>>>        
37008>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
37009>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
37010>>>>>        Set phoSessionDD to hoObj
37011>>>>>        
37011>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
37012>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
37013>>>>>        Set phoCrypto to hoObj
37014>>>>>        
37014>>>>>        Property Boolean pbPasswordHashing True
37015>>>>>        
37015>>>>>        Property Boolean pbCreatingNewSession False
37016>>>>>        Property String psLoginName
37017>>>>>        Property String psUserName ""
37018>>>>>        Property Integer piUserRights 0
37019>>>>>    End_Procedure
37020>>>>>    
37020>>>>>    Procedure End_Construct_Object
37022>>>>>        Forward Send End_Construct_Object
37024>>>>>        
37024>>>>>        Handle hoCrypto
37024>>>>>        Integer iFieldLen
37024>>>>>        If (pbPasswordHashing(Self)) Begin
37026>>>>>            Get phoCrypto to hoCrypto
37027>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37030>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37032>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37033>>>>>>
37033>>>>>            End
37033>>>>>>
37033>>>>>        End
37033>>>>>>
37033>>>>>    End_Procedure
37034>>>>>    
37034>>>>>    Function CreateSession String sRemoteAddress Returns String
37036>>>>>        String sSessionKey
37036>>>>>        Integer iErr
37036>>>>>        Boolean bLogWebSession
37036>>>>>        Handle hoSessionDD       
37036>>>>>        Get phoSessionDD to hoSessionDD
37037>>>>>        
37037>>>>>        //  Get session key
37037>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37039>>>>>        
37039>>>>>        Get pbLogWebSession to bLogWebSession
37040>>>>>        If not bLogWebSession Begin
37042>>>>>            Function_Return sSessionKey        
37043>>>>>        End
37043>>>>>>
37043>>>>>
37043>>>>>        //  Store session
37043>>>>>        Send Clear of hoSessionDD
37044>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37045>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37046>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37047>>>>>        Get Request_Validate of hoSessionDD to iErr
37048>>>>>        If (iErr) Begin
37050>>>>>            // this should not happen. If it does its a programming error
37050>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37051>>>>>>
37051>>>>>            Function_Return ""
37052>>>>>        End
37052>>>>>>
37052>>>>>        Send Request_Save of hoSessionDD
37053>>>>>        If (Err) Begin
37055>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37055>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37056>>>>>>
37056>>>>>            Function_Return ""
37057>>>>>        End
37057>>>>>>
37057>>>>>       
37057>>>>>        Function_Return sSessionKey        
37058>>>>>    End_Function
37059>>>>>    
37059>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37061>>>>>        DateTime dtLastAccess dtCurrent
37061>>>>>        TimeSpan tsDiff
37061>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37061>>>>>        Boolean bResult bCreatingNewSession
37061>>>>>        Boolean bLogWebSession bLoadWebApp
37061>>>>>        Integer eLoginMode
37061>>>>>        String sTime
37061>>>>>        Handle hoSessionDD hoUserDD       
37061>>>>>        
37061>>>>>        Move False to bLoadWebApp
37062>>>>>        If (num_arguments >= 2) Begin
37064>>>>>            Move bOptLoadWebApp to bLoadWebApp
37065>>>>>        End
37065>>>>>>
37065>>>>>        
37065>>>>>        Get phoSessionDD to hoSessionDD
37066>>>>>        Get phoUserDD to hoUserDD
37067>>>>>        
37067>>>>>        Get pbLogWebSession to bLogWebSession
37068>>>>>        Get peLoginMode to eLoginMode
37069>>>>>        
37069>>>>>        // for this object, you can only disable logging if login completely is disabled
37069>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37071>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37072>>>>>>
37072>>>>>            Function_Return False
37073>>>>>        End
37073>>>>>>
37073>>>>>
37073>>>>>        //  Clear session properties
37073>>>>>        Set psSessionKey to ""
37074>>>>>        Send UpdateSessionProperties True
37075>>>>>        
37075>>>>>        If not bLogWebSession Begin
37077>>>>>            Forward Get ValidateSession sSessionKey to bResult
37079>>>>>            Function_Return bResult
37080>>>>>        End        
37080>>>>>>
37080>>>>>        
37080>>>>>        Move False to bResult
37081>>>>>        Get piSessionTimeout to iSessionTimeout 
37082>>>>>        
37082>>>>>        //  Check if session exists
37082>>>>>        Send Clear of hoSessionDD
37083>>>>>        Move sSessionKey to WebAppSession.SessionKey
37084>>>>>        Send Find of hoSessionDD EQ Index.1
37085>>>>>            
37085>>>>>        If (Found) Begin
37087>>>>>            //  Calculate timespan between now and last access time
37087>>>>>            Move (CurrentDateTime()) to dtCurrent
37088>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37089>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37090>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37091>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37092>>>>>            
37092>>>>>            //  Check if session didn't time out
37092>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37094>>>>>                Forward Get ValidateSession sSessionKey to bResult
37096>>>>>                   
37096>>>>>                If (bResult) Begin
37098>>>>>                    //  Update session record
37098>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37099>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37100>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37101>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37102>>>>>                    Get Request_Validate of hoSessionDD to iErr
37103>>>>>                    If (iErr) Begin
37105>>>>>                        // this should not happen. If it does its a programming error
37105>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37106>>>>>>
37106>>>>>                        Function_Return False
37107>>>>>                    End
37107>>>>>>
37107>>>>>                    Send Request_Save of hoSessionDD
37108>>>>>                    
37108>>>>>                    //  Update user properties
37108>>>>>                    Send UpdateSessionProperties False
37109>>>>>                End
37109>>>>>>
37109>>>>>            End
37109>>>>>>
37109>>>>>            Else Begin
37110>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37110>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37111>>>>>                
37111>>>>>                If (not(bCreatingNewSession)) Begin
37113>>>>>                    If (not(bLoadWebApp)) Begin
37115>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37116>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37117>>>>>>
37117>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37118>>>>>                    End
37118>>>>>>
37118>>>>>                    Else Begin
37119>>>>>                        Set pbCreatingNewSession to True                    
37120>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37121>>>>>                        Set pbCreatingNewSession to False                        
37122>>>>>                    End
37122>>>>>>
37122>>>>>                End
37122>>>>>>
37122>>>>>            End
37122>>>>>>
37122>>>>>        End
37122>>>>>>
37122>>>>>        Else Begin
37123>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37124>>>>>>
37124>>>>>        End
37124>>>>>>
37124>>>>>        
37124>>>>>        Function_Return bResult
37125>>>>>    End_Function
37126>>>>>    
37126>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37128>>>>>        If (not(pbPasswordHashing(Self))) Begin
37130>>>>>            Move sPassword to sHash
37131>>>>>            Function_Return True
37132>>>>>        End
37132>>>>>>
37132>>>>>        
37132>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37134>>>>>            Function_Return False
37135>>>>>        End
37135>>>>>>
37135>>>>>        Move ("V1$" + sHash) to sHash
37136>>>>>        Function_Return True
37137>>>>>    End_Function
37138>>>>>    
37138>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37140>>>>>        If (not(pbPasswordHashing(Self))) Begin
37142>>>>>            Move False to bShouldUpgrade
37143>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37144>>>>>        End
37144>>>>>>
37144>>>>>        
37144>>>>>        String sVersion
37144>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37145>>>>>        If (sVersion = "V1$") Begin
37147>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37150>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37151>>>>>        End
37151>>>>>>
37151>>>>>        Else Begin
37152>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37155>>>>>            Function_Return False
37156>>>>>        End
37156>>>>>>
37156>>>>>    End_Function
37157>>>>>    
37157>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37159>>>>>        Handle hoUserDD
37159>>>>>        Integer iErr
37159>>>>>        Get phoUserDD to hoUserDD
37160>>>>>        
37160>>>>>        //  Find the user
37160>>>>>        Send Clear of hoUserDD
37161>>>>>        Move sLoginName to WebAppUser.LoginName
37162>>>>>        Send Find of hoUserDD EQ Index.1
37163>>>>>        If (Found) Begin
37165>>>>>            Send Clear of hoUserDD
37166>>>>>            Function_Return False
37167>>>>>        End
37167>>>>>>
37167>>>>>        
37167>>>>>        Send Clear of hoUserDD
37168>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37169>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37170>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37172>>>>>            Send Clear of hoUserDD
37173>>>>>            Function_Return False
37174>>>>>        End
37174>>>>>>
37174>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37175>>>>>        Get Request_Validate of hoUserDD to iErr
37176>>>>>        If (iErr) Begin
37178>>>>>            Send Clear of hoUserDD
37179>>>>>            Function_Return False
37180>>>>>        End
37180>>>>>>
37180>>>>>        
37180>>>>>        Send Request_Save of hoUserDD
37181>>>>>        Function_Return (not(Err))
37182>>>>>    End_Function
37183>>>>>    
37183>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37185>>>>>        String sSessionKey sUserPassword
37185>>>>>        Handle hoSessionDD hoUserDD
37185>>>>>        Boolean bMatch bUpgrade
37185>>>>>        
37185>>>>>        Get phoSessionDD to hoSessionDD
37186>>>>>        Get phoUserDD to hoUserDD
37187>>>>>        Integer iErr eLoginMode
37187>>>>>        
37187>>>>>        // Refind session record
37187>>>>>        Get psSessionKey to sSessionKey
37188>>>>>        Send Clear of hoSessionDD
37189>>>>>        Move sSessionKey to WebAppSession.SessionKey
37190>>>>>        Send Find of hoSessionDD EQ Index.1
37191>>>>>        
37191>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37193>>>>>            Get peLoginMode to eLoginMode
37194>>>>>            
37194>>>>>            //  Find the user
37194>>>>>            Move sLoginName to WebAppUser.LoginName
37195>>>>>            Send Find of hoUserDD EQ Index.1
37196>>>>>            
37196>>>>>            // Check username and password
