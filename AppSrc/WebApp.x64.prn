38271>>>            Function OnFileUpload String sFileName Integer iBytes String sMime Returns String
38274>>>                String sPath
38274>>>                Boolean bExists
38274>>>                Get UploadFolder True to sPath
38275>>>                Move (sPath + "\" + sFileName) to sPath
38276>>>                File_Exist sPath bExists
38277>>>                If (bExists) Begin
38279>>>                    EraseFile sPath
38280>>>>
38280>>>                End
38280>>>>
38280>>>                Function_Return sPath
38281>>>            End_Function
38282>>>            
38282>>>            Procedure OnFileFinished String sFileName String sLocalPath
38285>>>                String sExtension sDestPath sNewFileName
38285>>>
38285>>>                Forward Send OnFileFinished sFileName sLocalPath
38287>>>                
38287>>>                // 1. Obtener extensión
38287>>>
38287>>>                Move (Right(sFileName, Length(sFileName) - RightPos(".", sFileName))) to sExtension
38288>>>
38288>>>                // 2. Verificar que hay un registro de equipo cargado
38288>>>                If (sExtension <> "" and (HasRecord(oequipo_DD))) Begin
38290>>>                    Get EquipoEscudosFolder of oZoomEquipo to sDestPath
38291>>>                    
38291>>>                    // 3. Borrar escudo anterior si existe físicamente
38291>>>                    If (Trim(Equipo.Escudo) <> "") Begin
38293>>>                        EraseFile (sDestPath + "\" + Trim(Equipo.Escudo))
38294>>>>
38294>>>                    End
38294>>>>
38294>>>
38294>>>                    // 4. Definir nombre nuevo (ID.extensión)
38294>>>                    Move (String(Equipo.ID) + "." + sExtension) to sNewFileName
38295>>>                    Move (sDestPath + "\" + sNewFileName) to sDestPath
38296>>>                    
38296>>>                    // 5. Mover el archivo subido a la carpeta final
38296>>>                    CopyFile sLocalPath to sDestPath
38297>>>>
38297>>>                    EraseFile sLocalPath
38298>>>>
38298>>>
38298>>>                    // 6. ACTUALIZACIÓN SEGURA:
38298>>>                    // Para rellenar el campo escudo de la tabla equipo
38298>>>                    Set Field_Changed_Value of oequipo_DD Field Equipo.Escudo to sNewFileName
38299>>>                    
38299>>>                    // Guardamos los cambios en la base de datos
38299>>>                    Send Request_Save of oequipo_DD
38300>>>                    // 7. Refrescar el componente de imagen para ver el cambio
38300>>>                    Send Refresh of oWebImageEscudo 0 
38301>>>                End
38301>>>>
38301>>>                Else Begin
38302>>>                    EraseFile sLocalPath
38303>>>>
38303>>>                End
38303>>>>
38303>>>            End_Procedure
38304>>>
