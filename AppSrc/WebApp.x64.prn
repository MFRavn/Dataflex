39811>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39814>>>        WebSet pbRender of oNewButton to True
39815>>>        WebSet pbRender of oDetailButton to True
39816>>>
39816>>>        Case Begin
39816>>>            Case (NavigateData.eNavigateType = nfFromParent)
39818>>>                // If from parent, this is a constrained drill down
39818>>>                // If Row select does main-zoom we don't need this
39818>>>                WebSet pbRender of oDetailButton to False
39819>>>                Case Break
39820>>>
39820>>>            Case (NavigateData.eNavigateType = nfFromChild)
39823>>>                // If from child, this is a probably a parent lookup from a Zoom
39823>>>                Case Break
39824>>>
39824>>>            Case (NavigateData.eNavigateType = nfFromMain)
39827>>>                // If from main, this is a probably a main-file lookup from a Zoom
39827>>>                WebSet pbRender of oDetailButton to False
39828>>>                Case Break
39829>>>
39829>>>            Case Else // must be nfUndefined
39829>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
39829>>>                // If Row select does main-zoom we don't need this
39829>>>                WebSet pbRender of oDetailButton to False
39830>>>
39830>>>        Case End
39830>>>
39830>>>    End_Procedure
